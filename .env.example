# Configuración del Bot de Telegram
# Copia este archivo a .env y rellena con tus datos

# Token del bot de Telegram (obtenerlo de @BotFather)
BOT_TOKEN=your_telegram_bot_token_here

# Base de datos PostgreSQL
# Para desarrollo local: postgresql://usuario:contraseña@localhost:5432/pibot
# Para Heroku: Se configura automáticamente como DATABASE_URL
DATABASE_URL=postgresql://postgres:password@localhost:5432/pibot

# Configuración de moderación
MAX_MEDIA=4          # Máximo de medias (stickers, fotos, gifs) permitidas
WINDOW_TIME=15       # Ventana de tiempo en segundos
BAN_TIME=600         # Tiempo de baneo en segundos (10 minutos)

# IDs de temas (topics/threads) - Reemplaza con los IDs reales
THEME_PRESENTACIONES=3
THEME_ANUNCIOS=125337
THEME_BIBLIOTECA=28816
THEME_ESCUELA=28809
THEME_JUEGOS_CASINO=6791
THEME_RELATOS=50746
THEME_NSFW=834
THEME_EXHIBICIONISMO=4
THEME_BUSQUEDAS=2
THEME_POSTULACIONES=202530
THEME_MULTIMEDIA=50054

# ID del grupo de confesiones
CONFESIONES_GROUP_ID=-1002894647510
CONFESIONES_TOPIC_ID=7781
